                        <span class="label">Students</span>
                        <svg class="chev" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"><path d="M7.5 4.5l5.5 5.5-5.5 5.5" /></svg>
                    </button>
                    <ul class="submenu" id="sub-students">
                        <li><a href="#">Admissions</a></li>
                        <li><a href="#">Student directory</a></li>
                        <li><a href="#">Attendance</a></li>
                        <li><a href="#">Promotions</a></li>
                    </ul>
                </div>

                <div class="menu-group">
                    <button class="menu-item" aria-expanded="false" data-target="sub-staff">
                        <span class="icon"><svg viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><rect x="2.5" y="6.5" width="15" height="10" rx="1.4" /><path d="M7 6.5V5a2 2 0 0 1 2-2h2a2 2 0 0 1 2 2v1.5" /></svg></span>
                        <span class="label">Staff</span>
                        <svg class="chev" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"><path d="M7.5 4.5l5.5 5.5-5.5 5.5" /></svg>
                    </button>
                    <ul class="submenu" id="sub-staff">
                        <li><a href="#">Teaching staff</a></li>
                        <li><a href="#">Non-teaching staff</a></li>
                        <li><a href="#">Staff attendance</a></li>
                        <li><a href="#">Payroll</a></li>
                    </ul>
                </div>

                <div class="menu-group">
                    <button class="menu-item" aria-expanded="false" data-target="sub-academics">
                        <span class="icon"><svg viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M10 5.2c-1.3-1-3-1.4-4.7-1.2-1 .1-1.8.4-1.8 1v9.5c0 .6.8.9 1.8.8 1.7-.2 3.4.2 4.7 1.2 1.3-1 3-1.4 4.7-1.2 1 .1 1.8-.2 1.8-.8V5c0-.6-.8-.9-1.8-1-1.7-.2-3.4.2-4.7 1.2z" /><path d="M10 5.2v9.5" /></svg></span>
                        <span class="label">Academics</span>
                        <svg class="chev" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"><path d="M7.5 4.5l5.5 5.5-5.5 5.5" /></svg>
                    </button>
                    <ul class="submenu" id="sub-academics">
                        <li><a href="classes-form.html">Classes &amp; sections</a></li>
                        <li><a href="#">Subjects</a></li>
                        <li><a href="#">Timetable</a></li>
                        <li><a href="#">Exams &amp; results</a></li>
                        <li><a href="academic-years.html">Academic years</a></li>
                    </ul>
                </div>

                <div class="menu-group">
                    <button class="menu-item active-parent" aria-expanded="true" data-target="sub-billing">
                        <span class="icon"><svg viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><rect x="2.5" y="4.5" width="15" height="11" rx="1.6" /><path d="M2.5 8h15" /><path d="M5.5 12h3" /></svg></span>
                        <span class="label">Billing &amp; fees</span>
                        <svg class="chev" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"><path d="M7.5 4.5l5.5 5.5-5.5 5.5" /></svg>
                    </button>
                    <ul class="submenu open" id="sub-billing">
                        <li><a href="#">Fee structure</a></li>
                        <li><a href="fee-collection-form.html">Collect fee</a></li>
                        <li><a href="generate-fee-invoice.html">Generate invoice</a></li>
                        <li><a href="#">Dues &amp; reminders</a></li>
                        <li><a href="#">Payment history</a></li>
                    </ul>
                </div>

                <div class="menu-group">
                    <button class="menu-item" aria-expanded="false" data-target="sub-library">
                        <span class="icon"><svg viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3.5" width="4.5" height="13" rx="0.8" /><rect x="8.5" y="3.5" width="4.5" height="13" rx="0.8" /><path d="M14.3 4.5l3 .8-3 12-3-.8z" /></svg></span>
                        <span class="label">Library</span>
                        <svg class="chev" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"><path d="M7.5 4.5l5.5 5.5-5.5 5.5" /></svg>
                    </button>
                    <ul class="submenu" id="sub-library">
                        <li><a href="#">Catalogue</a></li>
                        <li><a href="#">Issued books</a></li>
                    </ul>
                </div>

                <div class="menu-group">
                    <button class="menu-item" aria-expanded="false" data-target="sub-transport">
                        <span class="icon"><svg viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><rect x="2.5" y="5" width="15" height="8.5" rx="1.6" /><circle cx="6" cy="15.5" r="1.5" /><circle cx="14" cy="15.5" r="1.5" /></svg></span>
                        <span class="label">Transport</span>
                        <svg class="chev" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"><path d="M7.5 4.5l5.5 5.5-5.5 5.5" /></svg>
                    </button>
                    <ul class="submenu" id="sub-transport">
                        <li><a href="#">Routes</a></li>
                        <li><a href="#">Vehicle tracking</a></li>
                    </ul>
                </div>

                <div class="menu-group">
                    <button class="menu-item" aria-expanded="false" data-target="sub-comm">
                        <span class="icon"><svg viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M10 3.5c-2.5 0-4.3 2-4.3 4.7v2.3l-1.2 2.3h11l-1.2-2.3V8.2c0-2.7-1.8-4.7-4.3-4.7z" /><path d="M8.4 15.2a1.7 1.7 0 0 0 3.2 0" /></svg></span>
                        <span class="label">Communication</span>
                        <svg class="chev" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"><path d="M7.5 4.5l5.5 5.5-5.5 5.5" /></svg>
                    </button>
                    <ul class="submenu" id="sub-comm">
                        <li><a href="#">Notices</a></li>
                        <li><a href="#">SMS &amp; email</a></li>
                    </ul>
                </div>

                <div class="menu-divider"></div>

                <a class="menu-flat" href="#">
                    <span class="icon"><svg viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M3 16V9l7-5 7 5v7" /><path d="M3 16h14" /><path d="M8 16v-4h4v4" /></svg></span>
                    <span class="label">Reports</span>
                </a>
                <a class="menu-flat" href="#">
                    <span class="icon"><svg viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><circle cx="10" cy="10" r="2.6" /><path d="M10 3.5v2M10 14.5v2M3.5 10h2M14.5 10h2M5.4 5.4l1.4 1.4M13.2 13.2l1.4 1.4M5.4 14.6l1.4-1.4M13.2 6.8l1.4-1.4" /></svg></span>
                    <span class="label">Settings</span>
                </a>
            </nav>
        </aside>

        <div class="main">
            <header class="topbar">
                <button class="hamburger" id="hamburger" aria-label="Toggle menu">
                    <svg width="18" height="18" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"><path d="M3 5.5h14M3 10h14M3 14.5h14" /></svg>
                </button>
                <div>
                    <h1>Dashboard overview</h1>
                    <p class="sub" id="topbar-date">Loading date…</p>
                </div>
                <div class="topbar-search">
                    <input type="text" placeholder="Search student, invoice, staff…">
                </div>
                <div class="topbar-right">
                    <button class="bell-btn" aria-label="Notifications">
                        <svg width="20" height="20" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M10 3.5c-2.5 0-4.3 2-4.3 4.7v2.3l-1.2 2.3h11l-1.2-2.3V8.2c0-2.7-1.8-4.7-4.3-4.7z" /><path d="M8.4 15.2a1.7 1.7 0 0 0 3.2 0" /></svg>
                        <span class="bell-dot"></span>
                    </button>
                    <div class="avatar">RA</div>
                </div>
            </header>
            <div>
                @RenderBody()
            </div>
        </div>
    </div>
    <script>
        document.querySelectorAll(".menu-item[data-target]").forEach(function(btn){
          btn.addEventListener("click", function(){
            var sub = document.getElementById(btn.dataset.target);
            var isOpen = sub.classList.contains("open");
            sub.classList.toggle("open", !isOpen);
            btn.setAttribute("aria-expanded", String(!isOpen));
            btn.classList.toggle("active-parent", !isOpen);
          });
        });

        var hamburger = document.getElementById("hamburger");
        var sidebar = document.getElementById("sidebar");
        var overlay = document.getElementById("overlay");
        function closeSidebar(){ sidebar.classList.remove("open"); overlay.classList.remove("show"); }
        hamburger.addEventListener("click", function(){
          sidebar.classList.toggle("open");
          overlay.classList.toggle("show");
        });
        overlay.addEventListener("click", closeSidebar);

        document.getElementById("topbar-date").textContent = new Date().toLocaleDateString("en-IN", { weekday:"long", day:"numeric", month:"long", year:"numeric" });

        var dues = [
          { cls:"Class 10", students:34, amount:148900 },
          { cls:"Class 9",  students:28, amount:112400 },
          { cls:"Class 12", students:22, amount:97300 },
          { cls:"Class 6",  students:19, amount:68200 },
          { cls:"Class 7",  students:39, amount:59950 }
        ];
        var maxDue = Math.max.apply(null, dues.map(function(d){ return d.amount; }));
        var duesBody = document.getElementById("dues-body");
        dues.forEach(function(d){
          var pct = Math.round((d.amount / maxDue) * 100);
          var tr = document.createElement("tr");
          tr.innerHTML =
            "<td>" + d.cls + "</td>" +
            "<td>" + d.students + "</td>" +
            "<td class=\"num\">₹" + d.amount.toLocaleString("en-IN") + "</td>" +
            "<td><div class=\"mini-bar\"><span style=\"width:" + pct + "%\"></span></div></td>";
          duesBody.appendChild(tr);
        });

        var txns = [
          { name:"Aarav Mehta",   cls:"10-B", inv:"INV-20261042", amt:24500, date:"23 Jun 2026", status:"paid" },
          { name:"Sneha Kapoor",  cls:"8-A",  inv:"INV-20261041", amt:18000, date:"23 Jun 2026", status:"pending" },
          { name:"Rohan Verma",   cls:"12-C", inv:"INV-20261039", amt:31200, date:"22 Jun 2026", status:"paid" },
          { name:"Ishita Sharma", cls:"6-D",  inv:"INV-20261036", amt:15750, date:"21 Jun 2026", status:"overdue" },
          { name:"Kabir Singh",   cls:"9-A",  inv:"INV-20261033", amt:22400, date:"20 Jun 2026", status:"paid" }
        ];
        var txnBody = document.getElementById("txn-body");
        txns.forEach(function(t){
          var tr = document.createElement("tr");
          tr.innerHTML =
            "<td>" + t.name + "</td>" +
            "<td>" + t.cls + "</td>" +
            "<td style=\"font-family:'JetBrains Mono',monospace; font-size:12px;\">" + t.inv + "</td>" +
            "<td class=\"num\">₹" + t.amt.toLocaleString("en-IN") + "</td>" +
            "<td>" + t.date + "</td>" +
            "<td><span class=\"badge " + t.status + "\">" + t.status.charAt(0).toUpperCase() + t.status.slice(1) + "</span></td>";
          txnBody.appendChild(tr);
        });

        var notices = [
          { day:"25", mon:"JUN", text:"Term 2 fee due date extended to 5 July." },
          { day:"27", mon:"JUN", text:"Parent-teacher meeting for classes 6–8." },
          { day:"01", mon:"JUL", text:"New session timetable to be released." }
        ];
        var noticeList = document.getElementById("notice-list");
        notices.forEach(function(n){
          var div = document.createElement("div");
          div.className = "notice-item";
          div.innerHTML =
            "<div class=\"notice-date\"><span class=\"d\">" + n.day + "</span>" + n.mon + "</div>" +
            "<div class=\"notice-text\">" + n.text + "</div>";
          noticeList.appendChild(div);
        });

        var targetPct = 78;
        var ring = document.getElementById("ring");
        var ringPct = document.getElementById("ring-pct");
        var cur = 0;
        var step = setInterval(function(){
          cur += 2;
          if(cur >= targetPct){ cur = targetPct; clearInterval(step); }
          ring.style.setProperty("--pct", cur);
          ringPct.textContent = cur + "%";
        }, 18);

        window.addEventListener("load", function(){
          var ctx = document.getElementById("feeChart");
          if(!ctx || !window.Chart) return;
          new Chart(ctx, {
            type: "bar",
            data: {
              labels: ["Jan","Feb","Mar","Apr","May","Jun"],
              datasets: [{
                label: "Fee collected (₹ lakh)",
                data: [14.2, 15.8, 16.5, 12.9, 16.9, 18.4],
                backgroundColor: "#152442",
                borderRadius: 4,
                maxBarThickness: 34
              }]
            },
            options: {
              responsive: true,
              maintainAspectRatio: false,
              plugins: { legend: { display: false } },
              scales: {
                y: { beginAtZero: true, grid: { color: "#ECE7DA" }, ticks: { color: "#7C8696", font: { size: 11 } } },
                x: { grid: { display: false }, ticks: { color: "#7C8696", font: { size: 11 } } }
              }
            }
          });
        });
    </script>
</body>
</html>
